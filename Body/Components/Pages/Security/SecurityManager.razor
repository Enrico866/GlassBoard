@page "/network/security/new"
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Abstractions.Service
@using GlassBoard.Provider
@using GlassBoard.Request.Add
@using SharedLibrary.Enum
@inject ISecurityService SecurityService
@inject ISecurityProvider SecurityProvider
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-6">
        <MudText Typo="Typo.h5" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Security" Class="mr-2 mb-n1" />
            Nuova Configurazione Security
        </MudText>

        <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <MudGrid>
                @* Info Base *@
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name" Label="Nome Identificativo" Variant="Variant.Outlined" Required="true" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudSelect T="SecretScopeTypes" Label="Secret Scope" @bind-Value="_model.SecretScope" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (SecretScopeTypes item in Enum.GetValues(typeof(SecretScopeTypes)))
                        {
                            <MudSelectItem Value="@item">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudSelect T="SecurityTypes" Label="Tipo Security" Value="_model.SecurityType" ValueChanged="OnSecurityTypeChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (SecurityTypes item in Enum.GetValues(typeof(SecurityTypes)))
                        {
                            <MudSelectItem Value="@item">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Configurazione Dettagliata</MudText>
                </MudItem>

                @* Logica campi dinamici (Invariata per brevità, ma punta a _model) *@
                @if (_model.SecurityType == SecurityTypes.Credential || _model.SecurityType == SecurityTypes.ApiAuth)
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Secret.Username" Label="Username" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Secret.Password" Label="Password" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                }

                @* ... Resto dei blocchi condizionali SNMP, Token, etc ... *@

                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton OnClick="Cancel" Class="mr-2">Annulla</MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_loading">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Salva Security
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private AddSecurityRequest _model = new();
    private bool _loading = false;

    protected override void OnInitialized()
    {
        ResetModel();
    }

    private void ResetModel()
    {
        _model = new AddSecurityRequest
        {
            SecurityType = SecurityTypes.Credential,
            SecretScope = SecretScopeTypes.MonitoringService,
            Secret = new SecretData()
        };
    }

    private void OnSecurityTypeChanged(SecurityTypes newType)
    {
        _model.SecurityType = newType;
        _model.Secret = new SecretData();

        if (newType == SecurityTypes.SnmpUsmAuth)
        {
            _model.Secret.SecurityLevel = SecurityLevelTypes.NoAuthNoPriv;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/security/list");

    private async Task HandleSubmit()
    {
        _loading = true;

        var success = await SecurityService.CreateSecurityConfigAsync(_model);

        if (success)
        {
            await SecurityProvider.InitializeAsync(forceRefresh: true);
            Snackbar.Add("Configurazione salvata con successo", Severity.Success);
            Navigation.NavigateTo("/network/security/new"); // O lista
        }
        else
        {
            Snackbar.Add("Errore durante il salvataggio", Severity.Error);
        }

        _loading = false;
    }
}