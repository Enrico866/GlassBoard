@using System.Net.Http.Headers
@using System.Net.Http.Json
@using GlassBoard.Request.Add
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Response.Get
@using SharedLibrary.Models
@using static SharedLibrary.Enum.Enums
@inject IProfileRuleProvider ProfileRuleProvider
@inject IObservableProvider ObservableProvider
@inject ICheckProvider CheckProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Class="mr-3 mb-n1" />
            Configurazione Profile Rule
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 700px; overflow-y: auto;">
            @if (!_isDataLoaded)
            {
                <div class="d-flex justify-center pa-10">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            }
            else
            {
                <MudGrid Dense="true">
                    @* --- SEZIONE PADRE --- *@
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary"><b>Regola Principale (Padre)</b></MudText>
                    </MudItem>

                    <MudItem xs="12" md="9">
                        <MudTextField @bind-Value="_model.Name" Label="Nome Regola*" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_model.Order" Label="Ordine" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudPaper Outlined="true" Class="pa-4 mt-2">
                            <MudGrid Dense="true">
                                <MudItem xs="12">
                                    <MudSelect T="ResourceTypes" Label="Tipi Risorsa Padre"
                                               MultiSelection="true"
                                               @bind-SelectedValues="_selectedParentResourceTypes"
                                               Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (ResourceTypes type in Enum.GetValues(typeof(ResourceTypes)))
                                        {
                                            <MudSelectItem Value="@type">@type.ToString()</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12">
                                    <div class="d-flex align-center justify-space-between mt-2">
                                        <MudText Typo="Typo.caption"><b>Attributi Matching Padre</b></MudText>
                                        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="() => AddAttribute(_model.MatchingRuleSet)">Aggiungi</MudButton>
                                    </div>
                                    @foreach (var attr in _model.MatchingRuleSet.Attributes)
                                    {
                                        <div class="d-flex gap-2 mb-2">
                                            <MudTextField @bind-Value="attr.Key" Label="Chiave" Margin="Margin.Dense" Variant="Variant.Outlined" />
                                            <MudTextField @bind-Value="attr.Value" Label="Valore" Margin="Margin.Dense" Variant="Variant.Outlined" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _model.MatchingRuleSet.Attributes.Remove(attr))" Size="Size.Small" />
                                        </div>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="4" Class="mt-2">
                        <MudSelect T="string" Label="Collection Profiles Padre" MultiSelection="true"
                                   @bind-SelectedValues="_selectedParentColProfiles" Variant="Variant.Outlined" Margin="Margin.Dense">
                            @foreach (var profile in ObservableProvider.GetAllAvailableProfiles())
                            {
                                <MudSelectItem Value="@profile.Id">@profile.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="mt-2">
                        <MudSelect T="string" Label="Check Profiles Padre" MultiSelection="true"
                                   @bind-SelectedValues="_selectedParentCheckProfiles" Variant="Variant.Outlined" Margin="Margin.Dense">
                            @foreach (var check in CheckProvider.Checks)
                            {
                                <MudSelectItem Value="@check.Id">@check.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="mt-2">
                        <MudSelect T="string" Label="Alert Profiles Padre" MultiSelection="true"
                                   @bind-SelectedValues="_selectedParentAlertProfiles" Variant="Variant.Outlined" Margin="Margin.Dense">
                            @* Aggiungere qui il loop se hai un AlertProvider, altrimenti placeholder *@
                        </MudSelect>
                    </MudItem>

                    @* --- SEZIONE FIGLI --- *@
                    <MudItem xs="12" Class="mt-6">
                        <div class="d-flex align-center justify-space-between">
                            <MudText Typo="Typo.subtitle1" Color="Color.Secondary"><b>Sotto-Regole (Children)</b></MudText>
                            <MudButton StartIcon="@Icons.Material.Filled.AccountTree" Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" OnClick="AddChildRule">
                                Aggiungi Regola Figlio
                            </MudButton>
                        </div>
                        <MudDivider Class="my-2" />
                    </MudItem>

                    @foreach (var child in _model.ChildrenProfileRules)
                    {
                        <MudItem xs="12">
                            <MudPaper Outlined="true" Class="pa-4 mb-2" Style="border-left: 6px solid var(--mud-palette-secondary);">
                                <div class="d-flex justify-end mb-2">
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" OnClick="@(() => _model.ChildrenProfileRules.Remove(child))" Size="Size.Small" />
                                </div>
                                <MudGrid Dense="true">
                                    <MudItem xs="12">
                                        <MudSelect T="ResourceTypes" Label="Tipi Risorsa Figlio"
                                                   MultiSelection="true"
                                                   @bind-SelectedValues="_selectedChildTypesMap[child]"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense">
                                            @foreach (ResourceTypes type in Enum.GetValues(typeof(ResourceTypes)))
                                            {
                                                <MudSelectItem Value="@type">@type.ToString()</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>

                                    <MudItem xs="12" md="4">
                                        <MudSelect T="string" Label="Collection Figlio" MultiSelection="true"
                                                   @bind-SelectedValues="_selectedChildColProfilesMap[child]" Variant="Variant.Outlined" Margin="Margin.Dense">
                                            @foreach (var profile in ObservableProvider.GetAllAvailableProfiles())
                                            {
                                                <MudSelectItem Value="@profile.Id">@profile.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudSelect T="string" Label="Check Figlio" MultiSelection="true"
                                                   @bind-SelectedValues="_selectedChildCheckProfilesMap[child]" Variant="Variant.Outlined" Margin="Margin.Dense">
                                            @foreach (var check in CheckProvider.Checks)
                                            {
                                                <MudSelectItem Value="@check.Id">@check.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudSelect T="string" Label="Alert Figlio" MultiSelection="true"
                                                   @bind-SelectedValues="_selectedChildAlertProfilesMap[child]" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        </MudSelect>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annulla</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(_loading || !_isDataLoaded)">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Salva Configurazione
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public ProfileRuleItem? EntityToEdit { get; set; }

    private AddProfileRuleHttpRequest _model = new();

    // MultiSelection Padre
    private IEnumerable<ResourceTypes> _selectedParentResourceTypes = new HashSet<ResourceTypes>();
    private IEnumerable<string> _selectedParentColProfiles = new HashSet<string>();
    private IEnumerable<string> _selectedParentCheckProfiles = new HashSet<string>();
    private IEnumerable<string> _selectedParentAlertProfiles = new HashSet<string>();

    // MultiSelection Figli (Mappe di stato)
    private Dictionary<ChildProfileRule, IEnumerable<ResourceTypes>> _selectedChildTypesMap = new();
    private Dictionary<ChildProfileRule, IEnumerable<string>> _selectedChildColProfilesMap = new();
    private Dictionary<ChildProfileRule, IEnumerable<string>> _selectedChildCheckProfilesMap = new();
    private Dictionary<ChildProfileRule, IEnumerable<string>> _selectedChildAlertProfilesMap = new();

    private bool _loading = false;
    private bool _isDataLoaded = false;
    private bool _isEdit => EntityToEdit != null;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            _model.Name = EntityToEdit!.Name;
            _model.Order = EntityToEdit.Order;
            _model.MatchingRuleSet = EntityToEdit.MatchingRuleSet ?? new();
            _model.ProfileSet = EntityToEdit.ProfileSet ?? new();
            _model.ChildrenProfileRules = EntityToEdit.ChildrenProfileRules ?? new();

            // Sincronizzazione UI Padre
            _selectedParentResourceTypes = _model.MatchingRuleSet.ResourceTypes?.Select(Enum.Parse<ResourceTypes>).ToHashSet() ?? new();
            _selectedParentColProfiles = _model.ProfileSet.CollectionProfileIds?.ToHashSet() ?? new();
            _selectedParentCheckProfiles = _model.ProfileSet.CheckProfileIds?.ToHashSet() ?? new();
            _selectedParentAlertProfiles = _model.ProfileSet.AlertProfileIds?.ToHashSet() ?? new();

            // Sincronizzazione UI Figli
            foreach (var child in _model.ChildrenProfileRules)
            {
                _selectedChildTypesMap[child] = child.MatchingRuleSet.ResourceTypes?.Select(Enum.Parse<ResourceTypes>).ToHashSet() ?? new();
                _selectedChildColProfilesMap[child] = child.ProfileSet.CollectionProfileIds?.ToHashSet() ?? new();
                _selectedChildCheckProfilesMap[child] = child.ProfileSet.CheckProfileIds?.ToHashSet() ?? new();
                _selectedChildAlertProfilesMap[child] = child.ProfileSet.AlertProfileIds?.ToHashSet() ?? new();
            }
        }

        await Task.WhenAll(ObservableProvider.InitializeAsync(), CheckProvider.InitializeAsync());
        _isDataLoaded = true;
    }

    private void AddChildRule()
    {
        var newChild = new ChildProfileRule();
        _model.ChildrenProfileRules.Add(newChild);
        _selectedChildTypesMap[newChild] = new HashSet<ResourceTypes>();
        _selectedChildColProfilesMap[newChild] = new HashSet<string>();
        _selectedChildCheckProfilesMap[newChild] = new HashSet<string>();
        _selectedChildAlertProfilesMap[newChild] = new HashSet<string>();
    }

    private void AddAttribute(MatchingRuleSet set)
    {
        set.Attributes ??= new();
        set.Attributes.Add(new AttributeRule());
    }

    private async Task Submit()
    {
        _loading = true;
        try
        {
            // Consolidamento dati Padre
            _model.MatchingRuleSet.ResourceTypes = _selectedParentResourceTypes.Select(x => x.ToString()).ToList();
            _model.ProfileSet.CollectionProfileIds = _selectedParentColProfiles.ToArray();
            _model.ProfileSet.CheckProfileIds = _selectedParentCheckProfiles.ToArray();
            _model.ProfileSet.AlertProfileIds = _selectedParentAlertProfiles.ToArray();

            // Consolidamento dati Figli
            foreach (var child in _model.ChildrenProfileRules)
            {
                child.MatchingRuleSet.ResourceTypes = _selectedChildTypesMap[child].Select(x => x.ToString()).ToList();
                child.ProfileSet.CollectionProfileIds = _selectedChildColProfilesMap[child].ToArray();
                child.ProfileSet.CheckProfileIds = _selectedChildCheckProfilesMap[child].ToArray();
                child.ProfileSet.AlertProfileIds = _selectedChildAlertProfilesMap[child].ToArray();
            }

            bool success = _isEdit
                ? await ProfileRuleProvider.UpdateProfileRuleAsync(EntityToEdit!.Id, _model)
                : await ProfileRuleProvider.AddProfileRuleAsync(_model);

            if (success) MudDialog.Close(DialogResult.Ok(true));
        }
        finally { _loading = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}