@page "/network/profile-rules"
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Response.Get
@using SharedLibrary.Models
@inject IProfileRuleProvider ProfileRuleProvider
@inject IObservableProvider ObservableProvider
@inject ICheckProvider CheckProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudText Typo="Typo.h5" Color="Color.Primary">Regole di Associazione Profili</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="() => OpenEditDialog(null)">
            Nuova Regola
        </MudButton>
    </MudStack>

    <MudDataGrid Items="@_rules" Loading="@_loading" Dense="true" Hover="true" Bordered="true" Striped="true" QuickFilter="@_quickFilter">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="Cerca regola..." Adornment="Adornment.Start" Immediate="true" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <HierarchyColumn T="ProfileRuleItem" />
            <PropertyColumn T="ProfileRuleItem" TProperty="int" Property="x => x.Order" Title="Ord." Width="60px" />
            <PropertyColumn T="ProfileRuleItem" TProperty="string" Property="x => x.Name" Title="Nome Regola" />

            <TemplateColumn T="ProfileRuleItem" Title="Matching Padre">
                <CellTemplate>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var type in context.Item.MatchingRuleSet.ResourceTypes)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@type</MudChip>
                        }
                    </div>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn T="ProfileRuleItem" Title="Collection Profiles">
                <CellTemplate>
                    <div class="d-flex flex-wrap gap-1">
                        @if (context.Item.ProfileSet.CollectionProfileIds?.Any() == true)
                        {
                            @foreach (var id in context.Item.ProfileSet.CollectionProfileIds)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@GetProfileName(id)</MudChip>
                            }
                        }
                    </div>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn T="ProfileRuleItem" Title="Check Profiles">
                <CellTemplate>
                    <div class="d-flex flex-wrap gap-1">
                        @if (context.Item.ProfileSet.CheckProfileIds?.Any() == true)
                        {
                            @foreach (var id in context.Item.ProfileSet.CheckProfileIds)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@GetCheckName(id)</MudChip>
                            }
                        }
                    </div>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn T="ProfileRuleItem" CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => OnDeleteClicked(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <ChildRowContent>
            <MudCard Elevation="0" Class="ma-4 pa-4" Style="background-color: var(--mud-palette-background-grey);">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Sotto-regole Figlie (@context.Item.ChildrenProfileRules.Count)</MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Resource Types</th>
                            <th>Profiles</th>
                            <th>Attributes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var child in context.Item.ChildrenProfileRules)
                        {
                            <tr>
                                <td>@string.Join(", ", child.MatchingRuleSet.ResourceTypes)</td>
                                <td>
                                    <small>Col: @(child.ProfileSet.CollectionProfileIds?.Length ?? 0), Check: @(child.ProfileSet.CheckProfileIds?.Length ?? 0)</small>
                                </td>
                                <td>
                                    @foreach (var attr in child.MatchingRuleSet.Attributes)
                                    {
                                        <code style="font-size: 0.7rem;">@attr.Key=@attr.Value </code>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudCard>
        </ChildRowContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<ProfileRuleItem> _rules = new();
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ObservableProvider.InitializeAsync(), CheckProvider.InitializeAsync());
        await LoadRules();
    }

    private async Task LoadRules()
    {
        _loading = true;
        try
        {
            var response = await ProfileRuleProvider.GetProfileRulesAsync();
            _rules = response?.Items ?? new();
        }
        finally { _loading = false; }
    }

    private async Task OpenEditDialog(ProfileRuleItem? item)
    {
        var parameters = new DialogParameters<AddProfileRuleDialog> { { x => x.EntityToEdit, item } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<AddProfileRuleDialog>(item == null ? "Nuova Regola" : "Modifica Regola", parameters, options);
        if (!(await dialog.Result).Canceled) await LoadRules();
    }

    private async Task OnDeleteClicked(ProfileRuleItem item)
    {
        bool? result = await DialogService.ShowMessageBox("Elimina", $"Eliminare la regola {item.Name}?", "Elimina", "Annulla");
        if (result == true)
        {
            if (await ProfileRuleProvider.DeleteProfileRuleAsync(item.Id)) await LoadRules();
        }
    }

    private string GetProfileName(string id) => ObservableProvider.GetAllAvailableProfiles().FirstOrDefault(p => p.Id == id)?.Name ?? id;
    private string GetCheckName(string id) => CheckProvider.Checks.FirstOrDefault(c => c.Id == id)?.Name ?? id;

    private Func<ProfileRuleItem, bool> _quickFilter => x => string.IsNullOrWhiteSpace(_searchString) || x.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
}