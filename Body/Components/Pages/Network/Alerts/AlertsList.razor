@page "/network/alerts"
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Models.Alerts
@inject IAlertProvider AlertProvider
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudText Typo="Typo.h4">Alerts Dashboard</MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="@AlertProvider.RefreshAlertsAsync"
                   Disabled="@AlertProvider.IsLoading">
            @(AlertProvider.IsLoading ? "Loading..." : "Refresh")
        </MudButton>
    </MudStack>

    <MudTable Items="@AlertProvider.Alerts"
              Loading="@AlertProvider.IsLoading"
              Hover="true"
              Breakpoint="Breakpoint.Sm"
              Elevation="4"
              RowsPerPage="10">
        <HeaderContent>
            <MudTh>Status</MudTh>
            <MudTh>Domain</MudTh>
            <MudTh>Resource</MudTh>
            <MudTh Style="width: 120px;">Gravity</MudTh>
            <MudTh>Created On</MudTh>
            <MudTh>Description</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Domain">
                <MudText Typo="Typo.caption" Style="display: block; text-transform: uppercase; color: var(--mud-palette-text-secondary);">
                    @context.Category
                </MudText>
                <MudText Typo="Typo.body2">@context.Domain</MudText>
            </MudTd>
            <MudTd DataLabel="Resource">
                <MudText Typo="Typo.body2" Color="Color.Primary"><b>@context.Resource?.Name</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.RootResource?.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Gravity">
                <MudStack Spacing="1">
                    <MudProgressLinear Color="@GetGravityColor(context.Gravity)"
                                       Value="@(context.Gravity * 20)"
                                       Class="my-1" />
                    <MudText Typo="Typo.caption" Align="Align.Center"><b>@context.Gravity.ToString("F1")</b></MudText>
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Created On">
                <MudText Typo="Typo.body2">@context.CreatedOn.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
                <MudText Typo="Typo.caption">@context.CreatedOn.ToLocalTime().ToString("HH:mm")</MudText>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Typo="Typo.body2" Style="max-width: 400px; word-wrap: break-word;">
                    @context.Description
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        AlertProvider.OnChange += StateHasChanged;

        if (!AlertProvider.Alerts.Any())
        {
            await AlertProvider.RefreshAlertsAsync();
        }
    }

    private Color GetStatusColor(string status) => status.ToLower() switch
    {
        "error" => Color.Error,
        "warning" => Color.Warning,
        "info" => Color.Info,
        _ => Color.Default
    };

    private Color GetGravityColor(double gravity) => gravity switch
    {
        >= 4.0 => Color.Error,
        >= 2.5 => Color.Warning,
        _ => Color.Success
    };

    public void Dispose()
    {
        AlertProvider.OnChange -= StateHasChanged;
    }
}