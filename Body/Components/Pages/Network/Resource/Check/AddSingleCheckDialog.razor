@using System.Net.Http.Headers
@using System.Net.Http.Json
@using GlassBoard.Abstractions
@using GlassBoard.Abstractions.Service
@using GlassBoard.Request
@using GlassBoard.Request.Add
@using GlassBoard.Response
@using GlassBoard.Response.Add
@using SharedLibrary.Enum
@inject HttpClient Http
@inject IAuthService AuthService
@inject IConfiguration Config
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddChart" Class="mr-3 mb-n1" />
            Nuovo Check Tecnico
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 600px; overflow-y: auto;">
            <MudGrid Dense="true">
                @* Info Base *@
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name" Label="Nome Check*" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="CheckCategoryTypes?" Label="Categoria" @bind-Value="_model.Category" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (CheckCategoryTypes item in Enum.GetValues(typeof(CheckCategoryTypes)))
                        {
                            <MudSelectItem Value="@((CheckCategoryTypes?)item)">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @* Configurazione Metriche (DataSampleQuery) *@
                <MudItem xs="12">
                    <div class="d-flex align-center justify-space-between mt-2">
                        <MudText Typo="Typo.subtitle2">Metriche Associate (Data Sample)</MudText>
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="AddMetricField" Color="Color.Info">Aggiungi Metrica</MudButton>
                    </div>
                    @if (_model.DataSampleQuery?.MetricQueries != null)
                    {
                        @foreach (var metric in _model.DataSampleQuery.MetricQueries)
                        {
                            <MudPaper Outlined="true" Class="pa-3 mt-1 mb-2" Style="background-color: var(--mud-palette-background-grey);">
                                <MudGrid Dense="true">
                                    <MudItem xs="12" md="5">
                                        <MudSelect T="string"
                                                   Value="metric.MetricName"
                                                   ValueChanged="@(value => OnQueryMetricChanged(value, metric))"
                                                   Label="Seleziona Metrica"
                                                   Margin="Margin.Dense">
                                            @foreach (var mName in AvailableMetrics)
                                            {
                                                <MudSelectItem Value="@mName">@mName</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="5">
                                        <MudTextField @bind-Value="metric.ProjectedMetricName" Label="Projected Name" Margin="Margin.Dense" Placeholder="es. val_1" />
                                    </MudItem>
                                    <MudItem xs="12" md="2" Class="d-flex align-center justify-end">
                                        <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" OnClick="@(() => _model.DataSampleQuery.MetricQueries.Remove(metric))" Size="Size.Small" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                </MudItem>

                @* Logica di Valutazione *@
                <MudItem xs="12" md="4">
                    <MudSelect T="CheckQueryTypes?" Label="Tipo Valutazione" Value="_model.CheckQueryType" ValueChanged="OnQueryTypeChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (CheckQueryTypes item in Enum.GetValues(typeof(CheckQueryTypes)))
                        {
                            <MudSelectItem Value="@((CheckQueryTypes?)item)">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    @if (_model.CheckQueryType == CheckQueryTypes.TimeRange)
                    {
                        <MudTextField @bind-Value="_itemsTimeRangeString" Label="Time Range (hh:mm:ss)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    }
                    else
                    {
                        <MudNumericField @bind-Value="_model.ItemsCount" Label="Items Count" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly="@(_model.CheckQueryType == CheckQueryTypes.Single)" />
                    }
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudSelect T="CheckStatusTypes?" Label="Stato Default" @bind-Value="_model.DefaultResult" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (CheckStatusTypes item in Enum.GetValues(typeof(CheckStatusTypes)))
                        {
                            <MudSelectItem Value="@((CheckStatusTypes?)item)">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @* Regole (RuleDefinitions) *@
                <MudItem xs="12" Class="mt-4">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle1"><b>Regole di Validazione</b></MudText>
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddRule" Size="Size.Small" Variant="Variant.Outlined">Nuova Regola</MudButton>
                    </div>
                    @if (_model.RuleDefinitions != null)
                    {
                        @foreach (var rule in _model.RuleDefinitions)
                        {
                            <MudPaper Outlined="true" Class="pa-3 mb-2">
                                <MudGrid Dense="true">
                                    <MudItem xs="12" md="3">
                                        <MudTextField @bind-Value="rule.Name" Label="Nome Regola" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" md="5">
                                        @if (rule.Condition != null)
                                        {
                                            <MudTextField @bind-Value="rule.Condition.Expression" Label="Condizione (es. > 80)" Margin="Margin.Dense" />
                                        }
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudSelect T="CheckStatusTypes?" Label="Status se Passa" @bind-Value="rule.ResultsOnPass" Margin="Margin.Dense">
                                            @foreach (CheckStatusTypes status in Enum.GetValues(typeof(CheckStatusTypes)))
                                            {
                                                <MudSelectItem Value="@((CheckStatusTypes?)status)">@status.ToString()</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="1" Class="d-flex align-center justify-end">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _model.RuleDefinitions.Remove(rule))" Size="Size.Small" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                </MudItem>

                @* Remediation *@
                <MudItem xs="12" Class="mt-2">
                    <MudText Typo="Typo.subtitle2" Class="mb-n2">Rimedio Suggerito</MudText>
                    <MudGrid Dense="true">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Remediation.Summary" Label="Sommario" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Remediation.SuggestedAction" Label="Azione Suggerita" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annulla</MudButton>
        <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="Submit" Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Salva Check
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter] public List<string> AvailableMetrics { get; set; } = new();

    private AddCheckHttpRequest _model = new();
    private string _itemsTimeRangeString = "00:05:00";
    private bool _loading = false;

    protected override void OnInitialized()
    {
        _model ??= new();
        _model.DataSampleQuery ??= new();
        _model.DataSampleQuery.MetricQueries ??= new();
        _model.RuleDefinitions ??= new();
        _model.Remediation ??= new();

        _model.CheckQueryType = CheckQueryTypes.TimeRange;
        _model.DefaultResult = CheckStatusTypes.Success;
        _model.Category = CheckCategoryTypes.Performance;

        if (!_model.DataSampleQuery.MetricQueries.Any())
        {
            AddMetricField();
        }

        if (!_model.RuleDefinitions.Any())
        {
            AddRule();
        }
    }

    private void AddMetricField()
    {
        _model.DataSampleQuery.MetricQueries.Add(new AddMetricDataSampleQueryHttpRequest());
    }

    private void OnQueryMetricChanged(string newMetric, AddMetricDataSampleQueryHttpRequest metricItem)
    {
        metricItem.MetricName = newMetric;

        if (!string.IsNullOrEmpty(newMetric))
        {
            // Sostituisce i punti con underscore
            string normalized = newMetric.Replace(".", "_");

            // 1. Compila il ProjectedMetricName della riga corrente
            metricItem.ProjectedMetricName = normalized;

            // 2. Compila il campo Expression della prima regola (se esiste ed è vuota o vuoi sovrascriverla)
            var firstRule = _model.RuleDefinitions.FirstOrDefault();
            if (firstRule?.Condition != null)
            {
                // Qui puoi decidere se aggiungere solo il nome o se inizializzarlo con uno spazio
                firstRule.Condition.Expression = $"{normalized} ";
            }
        }
    }

    private void OnQueryTypeChanged(CheckQueryTypes? newType)
    {
        _model.CheckQueryType = newType;
        if (newType == CheckQueryTypes.Single) { _model.ItemsCount = 1; }
        else if (newType == CheckQueryTypes.Count && (_model.ItemsCount ?? 0) <= 1) { _model.ItemsCount = 10; }
    }

    private void AddRule()
    {
        _model.RuleDefinitions.Add(new AddRuleDefinitionHttpRequest
        {
            ResultsOnPass = CheckStatusTypes.Success,
            Condition = new AddRuleConditionHttpRequest()
        });
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            Snackbar.Add("Il nome è obbligatorio", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            if (_model.CheckQueryType == CheckQueryTypes.TimeRange)
            {
                if (TimeSpan.TryParse(_itemsTimeRangeString, out var ts))
                {
                    _model.ItemsTimeRange = _itemsTimeRangeString;
                }
                _model.ItemsCount = null;
            }
            else
            {
                _model.ItemsTimeRange = null;
            }

            var token = await AuthService.GetContextAccessTokenAsync();
            var url = Config["ResourceApi:ChecksUrl"];

            using var request = new HttpRequestMessage(HttpMethod.Post, url);
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            request.Headers.Add("X-MYDEV-CHANNEL", Config["ResourceApi:Channel"]);
            request.Content = JsonContent.Create(_model);

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var res = await response.Content.ReadFromJsonAsync<AddCheckResponse>();
                Snackbar.Add("Check creato correttamente!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(res?.Id));
            }
            else
            {
                var errorDetail = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Errore API: {response.StatusCode}.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore di sistema: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }
}