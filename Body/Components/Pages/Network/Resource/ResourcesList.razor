@page "/network/resources"
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Response.Get
@inject IResourceProvider Provider
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudTable Items="@Provider.Resources"
              Loading="@_isLoading"
              Dense="true"
              Hover="true"
              Bordered="false"
              Striped="true"
              Elevation="4"
              Filter="new Func<ResourceApiDto, bool>(FilterFunc1)">

        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary"><b>Risorse di Rete</b></MudText>
            <MudSpacer />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddDialog"
                       Class="mr-4">
                Nuova Risorsa
            </MudButton>

            <MudTextField @bind-Value="_searchString"
                          Placeholder="Cerca per nome, IP o seriale..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0"
                          Clearable="true">
            </MudTextField>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>Stato</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ResourceApiDto, object>(x => x.Name)">Nome / Descrizione</MudTableSortLabel></MudTh>
            <MudTh>Hardware / OS</MudTh>
            <MudTh>Endpoint</MudTh>
            <MudTh>Severity</MudTh>
            <MudTh Style="width: 50px">Azioni</MudTh>
        </HeaderContent>

        <RowTemplate Context="resource">
            <MudTd DataLabel="Stato">
                <MudTooltip Text="@(resource.IsMonitored ? "Monitorata" : "Non Monitorata")">
                    <MudIcon Icon="@Icons.Material.Filled.Circle"
                             Size="Size.Small"
                             Style="@($"color: {(resource.IsMonitored ? "var(--mud-palette-success)" : "#9E9E9E")};")" />
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="Nome">
                <MudLink href="@($"/network/resource/{resource.Id}")" Color="Color.Primary">
                    <b>@resource.Name</b>
                </MudLink>
                <MudText Typo="Typo.caption" Display="Display.Block" Class="text-muted">@resource.Description</MudText>
                @foreach (var tag in resource.Tags.Take(3))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Class="mt-1">@tag</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Info">
                <MudText Typo="Typo.body2"><b>SN:</b> @resource.SerialNumber</MudText>
                <MudText Typo="Typo.caption">@resource.Os</MudText>
            </MudTd>
            <MudTd DataLabel="Endpoint">
                @if (resource.Accesses?.Any() == true)
                {
                    @foreach (var access in resource.Accesses)
                    {
                        <MudChip T="string" Icon="@Icons.Material.Filled.Language" Size="Size.Small" Variant="Variant.Outlined">
                            @access.Address
                        </MudChip>
                    }
                }
            </MudTd>
            <MudTd DataLabel="Severity">
                <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(resource.SeverityType)" Variant="Variant.Filled">
                    @resource.SeverityType
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                               Size="Size.Small"
                               Color="Color.Info"
                               Href="@($"/network/resource/{resource.Id}")" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Class="pa-4">Nessuna risorsa trovata corrispondente ai criteri.</MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" RowsPerPageString="Righe:" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private bool _isLoading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData(bool refresh = false)
    {
        _isLoading = true;
        try
        {
            await Provider.InitializeAsync(refresh);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel caricamento: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Color GetSeverityColor(string severity) => severity switch
    {
        "High" => Color.Error,
        "Medium" => Color.Warning,
        "Low" => Color.Success,
        _ => Color.Default
    };

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, BackdropClick = false };
        var dialog = await DialogService.ShowAsync<AddResourceDialog>("Configurazione Nuova Risorsa", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData(refresh: true);
        }
    }

    private bool FilterFunc1(ResourceApiDto element) => FilterFunc(element, _searchString);

    private bool FilterFunc(ResourceApiDto element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;

        // Ricerca estesa a nome, seriale e indirizzi IP
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (element.SerialNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (element.Accesses?.Any(a => a.Address.Contains(searchString)) == true) return true;

        return false;
    }
}