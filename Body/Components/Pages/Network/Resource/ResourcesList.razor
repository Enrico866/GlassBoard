@page "/network/resources"
@using GlassBoard.Abstractions
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Provider
@using GlassBoard.Response
@using GlassBoard.Response.Get
@using MudBlazor
@inject IResourceProvider Provider
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudTable Items="@Provider.Resources"
              Loading="@_isLoading"
              Dense="true"
              Hover="true"
              Bordered="false"
              Striped="true"
              Filter="new Func<ResourceApiDto, bool>(FilterFunc1)">

        <ToolBarContent>
            <MudText Typo="Typo.h6">Risorse di Rete</MudText>
            <MudSpacer />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddDialog"
                       Class="mr-4">
                Nuova Risorsa
            </MudButton>

            <MudTextField @bind-Value="_searchString"
                          Placeholder="Cerca risorsa..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0">
            </MudTextField>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>Nome</MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh>Endpoint Principal</MudTh>
            <MudTh Style="width: 50px">Azioni</MudTh>
        </HeaderContent>

        <RowTemplate Context="resource">
            <MudTd DataLabel="Nome">
                <div class="d-flex align-center">
                    @{
                        string statusColor = resource.IsMonitored ? "var(--mud-palette-success)" : "#9E9E9E";
                        string statusTooltip = resource.IsMonitored ? "Monitorata" : "Non Monitorata";
                    }
                    <MudTooltip Text="@statusTooltip">
                        <div style="@($"width: 12px; height: 12px; border-radius: 50%; background-color: {statusColor};")" class="mr-3"></div>
                    </MudTooltip>

                    <MudLink href="@($"/network/resource/{resource.Id}")">
                        <b>@resource.Name</b>
                    </MudLink>
                </div>
            </MudTd>
            <MudTd DataLabel="Tipo">
                @foreach (var type in resource.ResourceTypes)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@type</MudChip>
                }
            </MudTd>
            @if (resource.Accesses is not null && resource.Accesses.Any())
            {
                <MudTd DataLabel="Endpoint">
                    <code style="font-size: 0.75rem;">@resource.Accesses.First().Address</code>
                </MudTd>
            }
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                               Size="Size.Small"
                               Href="@($"/network/resource/{resource.Id}")" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText>Nessuna risorsa trovata.</MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" RowsPerPageString="Righe per pagina:" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private bool _isLoading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData(bool refresh = false)
    {
        _isLoading = true;
        try
        {
            // Il Provider decide se chiamare l'API o usare la cache
            await Provider.InitializeAsync(refresh);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true, BackdropClick = false };
        var dialog = await DialogService.ShowAsync<AddResourceDialog>("Nuova Risorsa", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            // Dopo l'aggiunta, forziamo il refresh del Provider
            await LoadData(refresh: true);
        }
    }

    private bool FilterFunc1(ResourceApiDto element) => FilterFunc(element, _searchString);

    private bool FilterFunc(ResourceApiDto element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        return element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase);
    }
}