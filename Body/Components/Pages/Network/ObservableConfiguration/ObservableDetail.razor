@page "/network/observable-configurations/detail/{Id}"
@using GlassBoard.Abstractions.Provider
@using GlassBoard.Response.Get
@inject IObservableProvider ObservableProvider
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

@if (_config == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack" Class="mb-4">Torna all'elenco</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenEditDialog">Modifica</MudButton>
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Informazioni Generali</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText><strong>Nome:</strong> @_config.Name</MudText>
                    <MudText><strong>Descrizione:</strong> @_config.Description</MudText>
                    <MudText><strong>Instrument:</strong> <MudChip T="string" Color="Color.Info">@_config.Instrument</MudChip></MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @if (_config.Collector != null)
        {
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.h6">Collector Assegnato</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText><strong>ID:</strong> @_config.Collector.Id</MudText>
                        <MudText><strong>Descrizione:</strong> @_config.Collector.Description</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <MudItem xs="12">
            <MudCard>
                <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Configurazione OID</MudText></CardHeaderContent></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="6"><MudText><strong>Scalar OID:</strong> @_config.ScalarOidTemplate</MudText></MudItem>
                        <MudItem xs="6"><MudText><strong>Table OID:</strong> @_config.TableOidTemplate</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12">
            <MudTable Items="_config.Details" Hover="true" Elevation="2">
                <ToolBarContent><MudText Typo="Typo.h6">Dettagli Raccolta Dati</MudText></ToolBarContent>
                <HeaderContent>
                    <MudTh>Nome</MudTh>
                    <MudTh>Tipo Risultato</MudTh>
                    <MudTh>Specifiche</MudTh>
                </HeaderContent>
                <RowTemplate Context="detail">
                    <MudTd>@detail.Name</MudTd>
                    <MudTd>@detail.ResultType</MudTd>
                    <MudTd>
                        @if (detail.ResultType == "Metric")
                        {
                            <MudText Typo="Typo.caption">
                                Kind: <b>@detail.MetricKind</b> |
                                Unit: <b>@detail.MetricUnit</b>

                                @if (!string.IsNullOrEmpty(detail.Conversion))
                                {
                                    <br />
                        
                                    <span>Conversion: <b>@detail.Conversion</b></span>
                                }
                            </MudText>
                        }
                        else if (detail.ResultType == "StructuredData")
                        {
                            <MudText Typo="Typo.caption">Column Ordinal: <b>@detail.ColumnOrdinal</b></MudText>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string Id { get; set; }
    private ObservableConfigurationDetailed _config;

    private async Task OpenEditDialog()
    {
        var parameters = new DialogParameters { ["ConfigToEdit"] = _config };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateObservableDialog>("Modifica Configurazione", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            // Ricarica i dati locali dopo la modifica
            await ObservableProvider.InitializeAsync(forceRefresh: true);
            _config = ObservableProvider.GetConfigs(null)[Id];
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        // Recupera la lista piatta dal provider e cerca il dettaglio
        var dict = ObservableProvider.GetConfigs(null);
        if (dict != null && dict.TryGetValue(Id, out var config))
        {
            _config = config;
        }
    }

    private void NavigateBack() => NavigationManager.NavigateTo("/network/observable-configurations");
}